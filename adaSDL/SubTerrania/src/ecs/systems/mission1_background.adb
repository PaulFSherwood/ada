   procedure Colour_At
     (Cell_X : Positive;
      Cell_Y : Positive;
      Red    : out Colour_Channel;
      Green  : out Colour_Channel;
      Blue   : out Colour_Channel) is
      X : Cell_X_Index := Cell_X_Index'First;
      Y : Cell_Y_Index := Cell_Y_Index'First;
      P : Packed_Colour;
   begin
      if Cell_X > Width_Cells then
         X := Cell_X_Index'Last;
      else
         X := Cell_X_Index (Cell_X);
      end if;

      if Cell_Y > Height_Cells then
         Y := Cell_Y_Index'Last;
      else
         Y := Cell_Y_Index (Cell_Y);
      end if;

      P := Pixels (Y, X);
      Red := Colour_Channel (P / 16#010000#);
      Green := Colour_Channel ((P / 16#000100#) mod 16#100#);
      Blue := Colour_Channel (P mod 16#100#);
   end Colour_At;

