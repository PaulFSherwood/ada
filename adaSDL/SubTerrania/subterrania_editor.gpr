with "gtkada";

project Subterrania_Editor is

   for Languages use ("Ada");

   for Source_Dirs use
     ("src/editor",
      "src/core",
      "src/ecs/systems");

   for Object_Dir use "obj/editor";
   for Exec_Dir use "bin";
   for Main use ("subterrania_editor.adb");

   package Compiler is
      for Default_Switches ("Ada") use
        ("-gnat2022",
         "-O0",
         "-g",
         "-gnatwa",
         "-gnatyM100");
   end Compiler;

end Subterrania_Editor;
