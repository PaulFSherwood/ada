<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk+" version="3.20"/>
  <object class="GtkWindow" id="main_window">
    <property name="title">SubTerrania Editor</property>
    <property name="default-width">1440</property>
    <property name="default-height">900</property>
    <property name="window-position">center</property>
    <signal name="destroy" handler="on_quit"/>
    <child>
      <object class="GtkBox" id="root_box">
        <property name="orientation">vertical</property>
        <child>
          <object class="GtkMenuBar" id="menu_bar">
            <child>
              <object class="GtkMenuItem"><property name="label">File</property>
                <child type="submenu"><object class="GtkMenu">
                  <child><object class="GtkMenuItem"><property name="label">New</property><signal name="activate" handler="on_new"/></object></child>
                  <child><object class="GtkMenuItem"><property name="label">Open</property><signal name="activate" handler="on_open"/></object></child>
                  <child><object class="GtkMenuItem"><property name="label">Save</property><signal name="activate" handler="on_save"/></object></child>
                  <child><object class="GtkMenuItem"><property name="label">Save As</property><signal name="activate" handler="on_save_as"/></object></child>
                  <child><object class="GtkSeparatorMenuItem"/></child>
                  <child><object class="GtkMenuItem"><property name="label">Quit</property><signal name="activate" handler="on_quit"/></object></child>
                </object></child>
              </object>
            </child>
            <child>
              <object class="GtkMenuItem"><property name="label">Edit</property>
                <child type="submenu"><object class="GtkMenu">
                  <child><object class="GtkMenuItem"><property name="label">Undo</property><signal name="activate" handler="on_undo"/></object></child>
                  <child><object class="GtkMenuItem"><property name="label">Redo</property><signal name="activate" handler="on_redo"/></object></child>
                  <child><object class="GtkMenuItem"><property name="label">Delete Selection</property><signal name="activate" handler="on_delete_selection"/></object></child>
                </object></child>
              </object>
            </child>
            <child>
              <object class="GtkMenuItem"><property name="label">View</property>
                <child type="submenu"><object class="GtkMenu">
                  <child><object class="GtkMenuItem"><property name="label">Fullscreen</property><signal name="activate" handler="on_fullscreen"/></object></child>
                  <child><object class="GtkMenuItem"><property name="label">Fit Map</property><signal name="activate" handler="on_fit_map"/></object></child>
                  <child><object class="GtkCheckMenuItem" id="grid_menu_item"><property name="label">Show Grid</property><property name="active">true</property><signal name="toggled" handler="on_grid_menu_toggled"/></object></child>
                </object></child>
              </object>
            </child>
            <child>
              <object class="GtkMenuItem"><property name="label">Project</property>
                <child type="submenu"><object class="GtkMenu">
                  <child><object class="GtkMenuItem"><property name="label">Validate</property><signal name="activate" handler="on_validate"/></object></child>
                  <child><object class="GtkMenuItem"><property name="label">Build Game</property><signal name="activate" handler="on_build_game"/></object></child>
                  <child><object class="GtkMenuItem"><property name="label">Playtest</property><signal name="activate" handler="on_playtest"/></object></child>
                </object></child>
              </object>
            </child>
            <child>
              <object class="GtkMenuItem"><property name="label">Help</property>
                <child type="submenu"><object class="GtkMenu">
                  <child><object class="GtkMenuItem"><property name="label">Help</property><signal name="activate" handler="on_help"/></object></child>
                  <child><object class="GtkMenuItem"><property name="label">About</property><signal name="activate" handler="on_about"/></object></child>
                </object></child>
              </object>
            </child>
          </object>
        </child>
        <child>
          <object class="GtkToolbar" id="toolbar">
            <child><object class="GtkToolButton"><property name="label">New</property><signal name="clicked" handler="on_new"/></object></child>
            <child><object class="GtkToolButton"><property name="label">Open</property><signal name="clicked" handler="on_open"/></object></child>
            <child><object class="GtkToolButton"><property name="label">Save</property><signal name="clicked" handler="on_save"/></object></child>
            <child><object class="GtkSeparatorToolItem"/></child>
            <child><object class="GtkToggleToolButton" id="select_tool"><property name="label">Select</property><property name="active">true</property><signal name="clicked" handler="on_tool_select"/></object></child>
            <child><object class="GtkToggleToolButton" id="brush_tool"><property name="label">Brush</property><signal name="clicked" handler="on_tool_brush"/></object></child>
            <child><object class="GtkToggleToolButton" id="eraser_tool"><property name="label">Erase</property><signal name="clicked" handler="on_tool_eraser"/></object></child>
            <child><object class="GtkToggleToolButton" id="pan_tool"><property name="label">Pan</property><signal name="clicked" handler="on_tool_pan"/></object></child>
            <child><object class="GtkSeparatorToolItem"/></child>
            <child><object class="GtkToggleToolButton" id="grid_tool"><property name="label">Grid</property><property name="active">true</property><signal name="toggled" handler="on_grid_toolbar_toggled"/></object></child>
            <child><object class="GtkToolButton"><property name="label">Fit</property><signal name="clicked" handler="on_fit_map"/></object></child>
            <child><object class="GtkToolButton"><property name="label">Playtest</property><signal name="clicked" handler="on_playtest"/></object></child>
            <child><object class="GtkToolButton"><property name="label">Build</property><signal name="clicked" handler="on_build_game"/></object></child>
          </object>
        </child>
        <child>
          <object class="GtkBox" id="work_area">
            <property name="orientation">horizontal</property>
            <child>
              <object class="GtkBox" id="left_panel">
                <property name="orientation">vertical</property>
                <property name="width-request">260</property>
                <property name="margin">6</property>
                <child><object class="GtkLabel"><property name="label">Project</property><property name="xalign">0</property></object></child>
                <child><object class="GtkButton"><property name="label">Level</property><signal name="clicked" handler="on_open_level_document"/></object></child>
                <child><object class="GtkButton"><property name="label">Player Ship</property><signal name="clicked" handler="on_open_player_document"/></object></child>
                <child><object class="GtkButton"><property name="label">Enemies</property><signal name="clicked" handler="on_open_enemy_document"/></object></child>
                <child><object class="GtkButton"><property name="label">Bosses / Encounters</property><signal name="clicked" handler="on_open_boss_document"/></object></child>
                <child><object class="GtkButton"><property name="label">Weapons</property><signal name="clicked" handler="on_open_weapon_document"/></object></child>
                <child><object class="GtkButton"><property name="label">Powerups</property><signal name="clicked" handler="on_open_powerup_document"/></object></child>
                <child><object class="GtkButton"><property name="label">Audio</property><signal name="clicked" handler="on_open_audio_document"/></object></child>
                <child><object class="GtkButton"><property name="label">Triggers / Objectives</property><signal name="clicked" handler="on_open_trigger_document"/></object></child>
                <child><object class="GtkSeparator"/></child>
                <child><object class="GtkLabel"><property name="label">Palette</property><property name="xalign">0</property></object></child>
                <child><object class="GtkButton"><property name="label">Wall Tile</property><signal name="clicked" handler="on_palette_wall"/></object></child>
                <child><object class="GtkButton"><property name="label">Water Tile</property><signal name="clicked" handler="on_palette_water"/></object></child>
                <child><object class="GtkButton"><property name="label">Landing Tile</property><signal name="clicked" handler="on_palette_landing"/></object></child>
                <child><object class="GtkButton"><property name="label">Start Tile</property><signal name="clicked" handler="on_palette_start"/></object></child>
                <child><object class="GtkButton"><property name="label">Space / Erase</property><signal name="clicked" handler="on_palette_space"/></object></child>
                <child><object class="GtkSeparator"/></child>
                <child><object class="GtkButton"><property name="label">Miner</property><signal name="clicked" handler="on_palette_miner"/></object></child>
                <child><object class="GtkButton"><property name="label">Enemy</property><signal name="clicked" handler="on_palette_enemy"/></object></child>
                <child><object class="GtkButton"><property name="label">Fuel</property><signal name="clicked" handler="on_palette_fuel"/></object></child>
                <child><object class="GtkButton"><property name="label">Shield</property><signal name="clicked" handler="on_palette_shield"/></object></child>
                <child><object class="GtkButton"><property name="label">Gate</property><signal name="clicked" handler="on_palette_gate"/></object></child>
                <child><object class="GtkButton"><property name="label">Platform</property><signal name="clicked" handler="on_palette_platform"/></object></child>
                <child><object class="GtkButton"><property name="label">Boss Spawn</property><signal name="clicked" handler="on_palette_boss"/></object></child>
              </object>
            </child>
            <child>
              <object class="GtkBox" id="center_panel">
                <property name="orientation">vertical</property>
                <property name="hexpand">true</property>
                <property name="vexpand">true</property>
                <child>
                  <object class="GtkNotebook" id="document_notebook">
                    <property name="hexpand">true</property>
                    <property name="vexpand">true</property>
                    <child><object class="GtkFrame" id="map_canvas_frame"><property name="label">Level Canvas</property><property name="hexpand">true</property><property name="vexpand">true</property></object></child>
                    <child><object class="GtkBox" id="player_page"><property name="orientation">vertical</property><property name="margin">12</property>
                      <child><object class="GtkLabel"><property name="label">Player Ship Editor</property><property name="xalign">0</property></object></child>
                      <child><object class="GtkEntry" id="player_name_entry"><property name="text">RescueShip01</property></object></child>
                      <child><object class="GtkEntry" id="player_sprite_entry"><property name="text">assets/images/sprites/ship01.png</property></object></child>
                      <child><object class="GtkEntry" id="player_thrust_entry"><property name="text">260</property></object></child>
                      <child><object class="GtkEntry" id="player_drag_entry"><property name="text">0.96</property></object></child>
                      <child><object class="GtkEntry" id="player_fuel_entry"><property name="text">100</property></object></child>
                      <child><object class="GtkEntry" id="player_shield_entry"><property name="text">100</property></object></child>
                      <child><object class="GtkEntry" id="player_engine_sound_entry"><property name="text">assets/audio/sfx/ship/thrust.wav</property></object></child>
                      <child><object class="GtkEntry" id="player_shield_hit_entry"><property name="text">assets/audio/sfx/shields/hit.wav</property></object></child>
                      <child><object class="GtkEntry" id="player_shield_low_entry"><property name="text">assets/audio/sfx/shields/low.wav</property></object></child>
                      <child><object class="GtkButton"><property name="label">Browse Ship Sprite</property><signal name="clicked" handler="on_browse_player_sprite"/></object></child>
                      <child><object class="GtkButton"><property name="label">Browse Player Sound</property><signal name="clicked" handler="on_browse_player_sound"/></object></child>
                    </object></child>
                    <child><object class="GtkBox" id="enemy_page"><property name="orientation">vertical</property><property name="margin">12</property>
                      <child><object class="GtkLabel"><property name="label">Enemy Template Editor</property><property name="xalign">0</property></object></child>
                      <child><object class="GtkEntry" id="enemy_name_entry"><property name="text">Enemy_Scout</property></object></child>
                      <child><object class="GtkEntry" id="enemy_health_entry"><property name="text">50</property></object></child>
                      <child><object class="GtkEntry" id="enemy_fire_rate_entry"><property name="text">1.5</property></object></child>
                    </object></child>
                    <child><object class="GtkBox" id="boss_page"><property name="orientation">vertical</property><property name="margin">12</property>
                      <child><object class="GtkLabel"><property name="label">Boss / Encounter Editor</property><property name="xalign">0</property></object></child>
                      <child><object class="GtkEntry" id="boss_name_entry"><property name="text">Boss_01</property></object></child>
                      <child><object class="GtkEntry" id="boss_hp_entry"><property name="text">300</property></object></child>
                      <child><object class="GtkEntry" id="boss_trigger_entry"><property name="text">Boss_Zone</property></object></child>
                      <child><object class="GtkEntry" id="boss_music_entry"><property name="text">assets/audio/music/boss01.mp3</property></object></child>
                      <child><object class="GtkEntry" id="boss_phase1_hp_entry"><property name="text">HP_ABOVE 200</property></object></child>
                      <child><object class="GtkEntry" id="boss_phase1_path_entry"><property name="text">Boss_01_Phase1</property></object></child>
                      <child><object class="GtkEntry" id="boss_phase2_hp_entry"><property name="text">HP_BELOW 200</property></object></child>
                      <child><object class="GtkEntry" id="boss_phase2_path_entry"><property name="text">Boss_01_Phase2</property></object></child>
                      <child><object class="GtkEntry" id="boss_phase3_hp_entry"><property name="text">HP_BELOW 80</property></object></child>
                      <child><object class="GtkEntry" id="boss_phase3_path_entry"><property name="text">Boss_01_Phase3</property></object></child>
                      <child><object class="GtkEntry" id="boss_normal_animation_entry"><property name="text">normal</property></object></child>
                      <child><object class="GtkEntry" id="boss_damaged_animation_entry"><property name="text">damaged</property></object></child>
                      <child><object class="GtkEntry" id="boss_critical_animation_entry"><property name="text">critical</property></object></child>
                      <child><object class="GtkEntry" id="boss_death_animation_entry"><property name="text">death</property></object></child>
                      <child><object class="GtkButton"><property name="label">Browse Boss Music</property><signal name="clicked" handler="on_browse_boss_music"/></object></child>
                    </object></child>
                    <child><object class="GtkBox" id="weapon_page"><property name="orientation">vertical</property><property name="margin">12</property>
                      <child><object class="GtkLabel"><property name="label">Weapon Editor</property><property name="xalign">0</property></object></child>
                      <child><object class="GtkEntry" id="weapon_name_entry"><property name="text">Laser</property></object></child>
                      <child><object class="GtkEntry" id="weapon_damage_entry"><property name="text">10</property></object></child>
                      <child><object class="GtkEntry" id="weapon_cooldown_entry"><property name="text">0.25</property></object></child>
                      <child><object class="GtkEntry" id="weapon_speed_entry"><property name="text">400</property></object></child>
                      <child><object class="GtkEntry" id="weapon_charge_entry"><property name="text">none,charging,charged</property></object></child>
                      <child><object class="GtkEntry" id="weapon_fire_sound_entry"><property name="text">assets/audio/sfx/weapons/laser_fire.wav</property></object></child>
                      <child><object class="GtkEntry" id="weapon_hit_sound_entry"><property name="text">assets/audio/sfx/weapons/laser_hit.wav</property></object></child>
                      <child><object class="GtkEntry" id="weapon_charge_sound_entry"><property name="text">assets/audio/sfx/weapons/laser_charge.wav</property></object></child>
                    </object></child>
                    <child><object class="GtkBox" id="powerup_page"><property name="orientation">vertical</property><property name="margin">12</property>
                      <child><object class="GtkLabel"><property name="label">Powerup Editor</property><property name="xalign">0</property></object></child>
                      <child><object class="GtkEntry" id="powerup_name_entry"><property name="text">Shield_Recharge</property></object></child>
                      <child><object class="GtkEntry" id="powerup_value_entry"><property name="text">25</property></object></child>
                      <child><object class="GtkEntry" id="powerup_duration_entry"><property name="text">0</property></object></child>
                      <child><object class="GtkEntry" id="powerup_sound_entry"><property name="text">assets/audio/sfx/pickups/shield.wav</property></object></child>
                    </object></child>
                    <child><object class="GtkBox" id="audio_page"><property name="orientation">vertical</property><property name="margin">12</property>
                      <child><object class="GtkLabel"><property name="label">Audio Assignments</property><property name="xalign">0</property></object></child>
                      <child><object class="GtkEntry" id="menu_music_entry"><property name="text">assets/audio/music/menu_carousel.mp3</property></object></child>
                      <child><object class="GtkEntry" id="music_entry"><property name="text">assets/audio/music/menu_carousel.mp3</property></object></child>
                      <child><object class="GtkEntry" id="level_music_entry"><property name="text">assets/audio/music/mission01.mp3</property></object></child>
                      <child><object class="GtkEntry" id="audio_boss_music_entry"><property name="text">assets/audio/music/boss01.mp3</property></object></child>
                      <child><object class="GtkButton"><property name="label">Browse Menu Music</property><signal name="clicked" handler="on_browse_menu_music"/></object></child>
                      <child><object class="GtkButton"><property name="label">Browse Level Music</property><signal name="clicked" handler="on_browse_level_music"/></object></child>
                      <child><object class="GtkButton"><property name="label">Browse Boss Music</property><signal name="clicked" handler="on_browse_audio_boss_music"/></object></child>
                    </object></child>
                    <child><object class="GtkBox" id="triggers_page"><property name="orientation">vertical</property><property name="margin">12</property>
                      <child><object class="GtkLabel"><property name="label">Triggers and Objectives</property><property name="xalign">0</property></object></child>
                      <child><object class="GtkButton"><property name="label">Add Trigger</property><signal name="clicked" handler="on_add_trigger"/></object></child>
                      <child><object class="GtkButton"><property name="label">Add Objective</property><signal name="clicked" handler="on_add_objective"/></object></child>
                      <child><object class="GtkButton"><property name="label">Add Event</property><signal name="clicked" handler="on_add_event"/></object></child>
                    </object></child>
                  </object>
                </child>
                <child>
                  <object class="GtkBox" id="bottom_panel">
                    <property name="orientation">horizontal</property>
                    <property name="height-request">160</property>
                    <child>
                      <object class="GtkScrolledWindow" id="output_scroller"><property name="hexpand">true</property><property name="vexpand">true</property>
                        <child><object class="GtkTextView" id="output_text_view"><property name="editable">false</property><property name="monospace">true</property></object></child>
                      </object>
                    </child>
                    <child><object class="GtkFrame" id="minimap_frame"><property name="label">Minimap</property><property name="width-request">220</property></object></child>
                  </object>
                </child>
              </object>
            </child>
            <child>
              <object class="GtkBox" id="right_panel">
                <property name="orientation">vertical</property>
                <property name="width-request">320</property>
                <property name="margin">6</property>
                <child>
                  <object class="GtkNotebook" id="inspector_notebook">
                    <property name="vexpand">true</property>
                    <child><object class="GtkBox" id="selected_inspector"><property name="orientation">vertical</property><property name="margin">12</property>
                      <child><object class="GtkLabel"><property name="label">Selected Item</property><property name="xalign">0</property></object></child>
                      <child><object class="GtkLabel" id="selected_name_label"><property name="label">Nothing selected</property><property name="xalign">0</property></object></child>
                      <child><object class="GtkLabel" id="selected_type_label"><property name="label">Select an item</property><property name="xalign">0</property></object></child>
                      <child><object class="GtkEntry" id="selected_x_entry"><property name="text">0</property></object></child>
                      <child><object class="GtkEntry" id="selected_y_entry"><property name="text">0</property></object></child>
                      <child><object class="GtkEntry" id="selected_w_entry"><property name="text">32</property></object></child>
                      <child><object class="GtkEntry" id="selected_h_entry"><property name="text">32</property></object></child>
                      <child><object class="GtkButton"><property name="label">Apply Geometry</property><signal name="clicked" handler="on_apply_selected_geometry"/></object></child>
                      <child><object class="GtkButton"><property name="label">Delete Selection</property><signal name="clicked" handler="on_delete_selection"/></object></child>
                    </object></child>
                    <child><object class="GtkBox" id="level_inspector"><property name="orientation">vertical</property><property name="margin">12</property>
                      <child><object class="GtkLabel"><property name="label">Level Properties</property><property name="xalign">0</property></object></child>
                      <child><object class="GtkEntry" id="level_name_entry"><property name="text">STAGE01</property></object></child>
                      <child><object class="GtkEntry" id="level_title_entry"><property name="text">MISSION 1</property></object></child>
                      <child><object class="GtkEntry" id="next_level_entry"><property name="text">assets/levels/stage02.map</property></object></child>
                      <child><object class="GtkEntry" id="background_entry"><property name="text">assets/images/maps/sub-terrania-mission-1.png</property></object></child>
                      <child><object class="GtkEntry" id="level_boss_music_entry"><property name="text">assets/audio/music/boss01.mp3</property></object></child>
                      <child><object class="GtkButton"><property name="label">Browse Background</property><signal name="clicked" handler="on_browse_background"/></object></child>
                      <child><object class="GtkButton"><property name="label">Apply Level Properties</property><signal name="clicked" handler="on_apply_level_properties"/></object></child>
                      <child><object class="GtkButton"><property name="label">Save Project Assets</property><signal name="clicked" handler="on_save_project_assets"/></object></child>
                    </object></child>
                  </object>
                </child>
                <child><object class="GtkLabel" id="status_label"><property name="label">Ready</property><property name="xalign">0</property></object></child>
                <child><object class="GtkLabel" id="tool_status_label"><property name="label">Tool: Select    Brush: Wall</property><property name="xalign">0</property></object></child>
              </object>
            </child>
          </object>
        </child>
      </object>
    </child>
  </object>
</interface>
